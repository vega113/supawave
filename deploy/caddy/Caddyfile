{$CANONICAL_HOST} {
  encode zstd gzip
  reverse_proxy wave:{$WAVE_INTERNAL_PORT} {
    # During rolling updates both old and new containers share the
    # "wave" DNS name.  Health checks let Caddy route only to the
    # container that is ready, eliminating dropped requests.
    health_uri /healthz
    health_interval 2s
    health_timeout 3s

    # Retry on the (briefly) unhealthy upstream while the other is
    # still starting / stopping.
    lb_try_duration 5s
    lb_try_interval 250ms
  }
}

{$ROOT_HOST} {
  redir https://{$CANONICAL_HOST}{uri} permanent
}

{$WWW_HOST} {
  redir https://{$CANONICAL_HOST}{uri} permanent
}
