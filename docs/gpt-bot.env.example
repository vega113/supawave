# SupaWave management access used when registering or updating the robot.
SUPAWAVE_BASE_URL=https://supawave.ai
GPTBOT_MANAGEMENT_TOKEN=replace-with-a-management-bearer-token

# Robot identity and secret returned by /api/robots.
GPTBOT_ROBOT_NAME=gpt-bot
GPTBOT_PARTICIPANT_ID=gpt-bot@example.com
GPTBOT_API_ROBOT_ID=gpt-bot@example.com
GPTBOT_API_ROBOT_SECRET=replace-with-the-robot-secret

# Public callback origin after you start a tunnel.
GPTBOT_PUBLIC_BASE_URL=

# Runtime listener.
GPTBOT_LISTEN_HOST=0.0.0.0
GPTBOT_LISTEN_PORT=8087

# Reply transport and optional context fetch mode.
GPTBOT_REPLY_MODE=passive
GPTBOT_CONTEXT_MODE=none

# Local Codex CLI settings.
GPTBOT_CODEX_BINARY=codex
GPTBOT_CODEX_MODEL=gpt-5.4-mini
GPTBOT_CODEX_REASONING_EFFORT=low
GPTBOT_CODEX_TIMEOUT_SECONDS=120

# Optional profile metadata exposed by /_wave/robot/profile.
GPTBOT_PROFILE_URL=https://supawave.ai/api-docs
