<!-- Template for SearchWidget. Author: hearnden@google.com (David Hearnden) -->
<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder" xmlns:g="urn:import:com.google.gwt.user.client.ui">
  <ui:with
    field="css" type="org.waveprotocol.box.webclient.search.SearchWidget.Css" />
  <ui:with
    field="msg" type="org.waveprotocol.box.webclient.search.i18n.SearchWidgetMessages" />
  <g:HTMLPanel styleName='{css.self}'>
   <div class='{css.search}'>
     <g:TextBox ui:field='query' styleName='{css.query}'/>
     <div ui:field='helpButton' class='{css.helpButton}' title='Search help'>?</div>
   </div>
   <div ui:field='helpBackdrop' class='{css.helpBackdrop}' style='display:none'/>
   <div ui:field='helpPanel' class='{css.helpPanel}' style='display:none'>
     <div class='{css.helpHeader}'>
       <span class='{css.helpTitle}'>Search Help</span>
       <div ui:field='helpCloseButton' class='{css.helpClose}'>Got it</div>
     </div>
     <div ui:field='helpColumnsDiv' class='{css.helpColumns}'>
       <!-- Left column: Filters -->
       <div class='{css.helpColumn}'>
         <div class='{css.helpSectionTitle}'>Filters</div>
         <table class='{css.helpTable}'>
           <tr class='{css.helpTableHeader}'>
             <th>Filter</th><th>Description</th>
           </tr>
           <tr>
             <td><span ui:field='exInbox' class='{css.helpExample}'>in:inbox</span></td>
             <td>Waves in your inbox</td>
           </tr>
           <tr>
             <td><span ui:field='exArchive' class='{css.helpExample}'>in:archive</span></td>
             <td>Archived waves</td>
           </tr>
           <tr>
             <td><span ui:field='exAll' class='{css.helpExample}'>in:all</span></td>
             <td>All waves including public</td>
           </tr>
           <tr>
             <td><span ui:field='exPinned' class='{css.helpExample}'>in:pinned</span></td>
             <td>Pinned waves</td>
           </tr>
           <tr>
             <td><code>with:user@domain</code></td>
             <td>Waves with a participant &#x2014; try: <span ui:field='exWithTry' class='{css.helpExample}'>with:alice@example.com</span></td>
           </tr>
           <tr>
             <td><span ui:field='exPublic' class='{css.helpExample}'>with:@</span></td>
             <td>Public waves (shared domain)</td>
           </tr>
           <tr>
             <td><code>creator:user@domain</code></td>
             <td>Waves created by someone &#x2014; try: <span ui:field='exCreatorTry' class='{css.helpExample}'>creator:bob@example.com</span></td>
           </tr>
           <tr>
             <td><code>tag:name</code></td>
             <td>Waves with a specific tag &#x2014; try: <span ui:field='exTagTry' class='{css.helpExample}'>tag:important</span></td>
           </tr>
           <tr>
             <td><span ui:field='exUnread' class='{css.helpExample}'>unread:true</span></td>
             <td>Only waves with unread blips</td>
           </tr>
           <tr>
             <td><code>title:text</code></td>
             <td>Waves whose title contains text &#x2014; try: <span ui:field='exTitleTry' class='{css.helpExample}'>title:meeting</span></td>
           </tr>
           <tr>
             <td><code>content:text</code></td>
             <td>Waves containing text in any blip &#x2014; try: <span ui:field='exContentTry' class='{css.helpExample}'>content:agenda</span></td>
           </tr>
           <tr ui:field='mentionsFilterRow'>
             <td><span ui:field='exMentions' class='{css.helpExample}'>mentions:me</span></td>
             <td>Waves where you are @mentioned</td>
           </tr>
           <tr ui:field='tasksFilterRow'>
             <td><span ui:field='exTasks' class='{css.helpExample}'>tasks:me</span></td>
             <td>Waves with tasks assigned to you</td>
           </tr>
           <tr>
             <td><em>free text</em></td>
             <td>Implicit content: search &#x2014; try: <span ui:field='exFreeTextTry' class='{css.helpExample}'>meeting notes</span></td>
           </tr>
         </table>
       </div>
       <!-- Right column: Sort Options -->
       <div class='{css.helpColumn}'>
         <div class='{css.helpSectionTitle}'>Sort Options</div>
         <table class='{css.helpTable}'>
           <tr class='{css.helpTableHeader}'>
             <th>Sort</th><th>Description</th>
           </tr>
           <tr>
             <td><span ui:field='exSortDateDesc' class='{css.helpExample}'>orderby:datedesc</span></td>
             <td>Last modified, newest first (default)</td>
           </tr>
           <tr>
             <td><span ui:field='exSortDateAsc' class='{css.helpExample}'>orderby:dateasc</span></td>
             <td>Last modified, oldest first</td>
           </tr>
           <tr>
             <td><span ui:field='exSortCreatedDesc' class='{css.helpExample}'>orderby:createddesc</span></td>
             <td>Created time, newest first</td>
           </tr>
           <tr>
             <td><span ui:field='exSortCreatedAsc' class='{css.helpExample}'>orderby:createdasc</span></td>
             <td>Created time, oldest first</td>
           </tr>
           <tr>
             <td><span ui:field='exSortCreatorDesc' class='{css.helpExample}'>orderby:creatordesc</span></td>
             <td>Creator email Z&#x2192;A</td>
           </tr>
           <tr>
             <td><span ui:field='exSortCreatorAsc' class='{css.helpExample}'>orderby:creatorasc</span></td>
             <td>Creator email A&#x2192;Z</td>
           </tr>
         </table>
         <div class='{css.helpSectionTitle}' style='margin-top:10px'>Combinations</div>
         <div class='{css.helpCombiningText}'>
           Filters combine freely. The default sort is <code>orderby:datedesc</code> (newest first).
         </div>
         <div class='{css.helpExamplesGrid}' style='margin-top:6px'>
           <span ui:field='exInboxTag' class='{css.helpExample}'>in:inbox tag:important</span>
           <span ui:field='exAllOldest' class='{css.helpExample}'>in:all orderby:createdasc</span>
           <span ui:field='exWithTag' class='{css.helpExample}'>with:alice@example.com tag:project</span>
           <span ui:field='exPinnedCreator' class='{css.helpExample}'>in:pinned orderby:creatordesc</span>
           <span ui:field='exCreatorArchive' class='{css.helpExample}'>creator:bob in:archive</span>
           <span ui:field='exMentionsUnread' class='{css.helpExample}'>mentions:me unread:true</span>
         </div>
       </div>
     </div>
   </div>
  </g:HTMLPanel>
</ui:UiBinder>
