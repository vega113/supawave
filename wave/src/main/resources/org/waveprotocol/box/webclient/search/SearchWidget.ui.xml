<!-- Template for SearchWidget. Author: hearnden@google.com (David Hearnden) -->
<!DOCTYPE ui:UiBinder SYSTEM "http://dl.google.com/gwt/DTD/xhtml.ent">
<ui:UiBinder xmlns:ui="urn:ui:com.google.gwt.uibinder" xmlns:g="urn:import:com.google.gwt.user.client.ui">
  <ui:with
    field="css" type="org.waveprotocol.box.webclient.search.SearchWidget.Css" />
  <ui:with
    field="msg" type="org.waveprotocol.box.webclient.search.i18n.SearchWidgetMessages" />
  <g:HTMLPanel styleName='{css.self}'>
   <div class='{css.search}'>
     <g:TextBox ui:field='query' styleName='{css.query}'/>
     <div ui:field='helpButton' class='{css.helpButton}' title='Search help'>?</div>
   </div>
   <div ui:field='helpBackdrop' class='{css.helpBackdrop}' style='display:none'/>
   <div ui:field='helpPanel' class='{css.helpPanel}' style='display:none'>
     <div class='{css.helpHeader}'>
       <span class='{css.helpTitle}'>Search Help</span>
       <div ui:field='helpCloseButton' class='{css.helpClose}'>Got it</div>
     </div>
     <div class='{css.helpColumns}'>
       <!-- Left column: Filters -->
       <div class='{css.helpColumn}'>
         <div class='{css.helpSectionTitle}'>Filters</div>
         <table class='{css.helpTable}'>
           <tr class='{css.helpTableHeader}'>
             <th>Filter</th><th>Description</th>
           </tr>
           <tr>
             <td><code>in:inbox</code></td>
             <td>Waves in your inbox</td>
           </tr>
           <tr>
             <td><code>in:archive</code></td>
             <td>Archived waves</td>
           </tr>
           <tr>
             <td><code>in:all</code></td>
             <td>All waves including public</td>
           </tr>
           <tr>
             <td><code>in:pinned</code></td>
             <td>Pinned waves</td>
           </tr>
           <tr>
             <td><code>with:user@domain</code></td>
             <td>Waves with specific participant</td>
           </tr>
           <tr>
             <td><code>with:@</code></td>
             <td>Public waves (shared domain)</td>
           </tr>
           <tr>
             <td><code>creator:user@domain</code></td>
             <td>Waves created by someone</td>
           </tr>
           <tr>
             <td><code>tag:name</code></td>
             <td>Waves with a specific tag</td>
           </tr>
           <tr>
             <td><code>title:text</code></td>
             <td>Waves whose title contains text</td>
           </tr>
           <tr>
             <td><code>content:text</code></td>
             <td>Waves containing text in any blip</td>
           </tr>
           <tr>
             <td><em>free text</em></td>
             <td>Implicit <code>content:</code> search in wave content</td>
           </tr>
         </table>
       </div>
       <!-- Right column: Sort Options -->
       <div class='{css.helpColumn}'>
         <div class='{css.helpSectionTitle}'>Sort Options</div>
         <table class='{css.helpTable}'>
           <tr class='{css.helpTableHeader}'>
             <th>Sort</th><th>Description</th>
           </tr>
           <tr>
             <td><code>orderby:datedesc</code></td>
             <td>Last modified, newest first (default)</td>
           </tr>
           <tr>
             <td><code>orderby:dateasc</code></td>
             <td>Last modified, oldest first</td>
           </tr>
           <tr>
             <td><code>orderby:createddesc</code></td>
             <td>Created time, newest first</td>
           </tr>
           <tr>
             <td><code>orderby:createdasc</code></td>
             <td>Created time, oldest first</td>
           </tr>
           <tr>
             <td><code>orderby:creatordesc</code></td>
             <td>Creator email Z&#x2192;A</td>
           </tr>
           <tr>
             <td><code>orderby:creatorasc</code></td>
             <td>Creator email A&#x2192;Z</td>
           </tr>
         </table>
         <div class='{css.helpSectionTitle}' style='margin-top:10px'>Combining</div>
         <div class='{css.helpCombiningText}'>
           Filters can be combined freely. Plain text searches content: <code>hello world</code> finds waves containing those words. The default sort is <code>orderby:datedesc</code> (newest first).
         </div>
       </div>
     </div>
     <!-- Examples section spanning full width -->
     <div class='{css.helpSectionTitle}' style='margin-top:8px'>Examples &#x2014; click to search</div>
     <div class='{css.helpExamplesGrid}'>
       <span ui:field='exInbox' class='{css.helpExample}'>in:inbox</span>
       <span ui:field='exArchive' class='{css.helpExample}'>in:archive</span>
       <span ui:field='exAll' class='{css.helpExample}'>in:all</span>
       <span ui:field='exPinned' class='{css.helpExample}'>in:pinned</span>
       <span ui:field='exWith' class='{css.helpExample}'>with:alice@example.com</span>
       <span ui:field='exPublic' class='{css.helpExample}'>with:@</span>
       <span ui:field='exCreator' class='{css.helpExample}'>creator:bob</span>
       <span ui:field='exTag' class='{css.helpExample}'>tag:important</span>
       <span ui:field='exFreeText' class='{css.helpExample}'>meeting notes</span>
       <span ui:field='exInboxTag' class='{css.helpExample}'>in:inbox tag:important</span>
       <span ui:field='exAllOldest' class='{css.helpExample}'>in:all orderby:createdasc</span>
       <span ui:field='exWithTag' class='{css.helpExample}'>with:alice@example.com tag:project</span>
       <span ui:field='exPinnedCreator' class='{css.helpExample}'>in:pinned orderby:creatordesc</span>
       <span ui:field='exCreatorArchive' class='{css.helpExample}'>creator:bob in:archive</span>
       <span ui:field='exTitle' class='{css.helpExample}'>title:meeting</span>
       <span ui:field='exContent' class='{css.helpExample}'>content:agenda</span>
     </div>
   </div>
  </g:HTMLPanel>
</ui:UiBinder>
