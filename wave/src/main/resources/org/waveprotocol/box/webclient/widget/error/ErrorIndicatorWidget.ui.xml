<!--
  Template for ErrorIndicator — SupaWave ocean/dark floating toast.
  NOTE: @keyframes animations are injected via ErrorIndicatorWidget.java
  because GWT's CSS parser does not support @keyframes.
-->
<ui:UiBinder
    xmlns:ui="urn:ui:com.google.gwt.uibinder"
    xmlns:gwt="urn:import:com.google.gwt.user.client.ui"
>
  <ui:with field='msg'
         type='org.waveprotocol.box.webclient.widget.error.i18n.ErrorMessages' />

  <ui:style type='org.waveprotocol.box.webclient.widget.error.ErrorIndicatorWidget.Style'>

  .overlay {
    position: fixed;
    top: 16px;
    left: 50%;
    z-index: 99999;
    width: 520px;
    font-family: sans-serif;
    font-size: 14px;
    overflow: hidden;
    user-select: text;
  }

  .header {
    position: relative;
    padding: 20px 22px 16px 22px;
  }

  .message {
    display: flex;
    gap: 12px;
  }

  .actions {
    display: flex;
    gap: 8px;
    margin-top: 14px;
  }

  .btn {
    display: inline-block;
    padding: 6px 14px;
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
  }

  .btnPrimary {
    font-weight: 600;
  }

  .detail {
    max-height: 0;
    overflow-y: auto;
    padding: 0 22px;
    font-size: 12px;
    line-height: 1.4;
    user-select: text;
  }

  .expanded {
    max-height: 300px;
    padding: 14px 22px;
  }

  .stack {
    white-space: pre-wrap;
    word-break: break-all;
    font-family: monospace;
    font-size: 11px;
    user-select: text;
  }

  </ui:style>
  <gwt:HTMLPanel>
    <div ui:field="overlay" class="{style.overlay}">
      <!-- Wave decoration at the bottom (positioned by inline styles set in Java) -->
      <div ui:field="waveDecor" style="position: absolute; bottom: 0; left: 0; right: 0; height: 28px; overflow: hidden; pointer-events: none;"></div>

      <div class="{style.header}">
        <div class="{style.message}">
          <!-- Glowing dot indicator -->
          <span ui:field="glowDot" style="display: inline-block; width: 10px; height: 10px; min-width: 10px; border-radius: 50%; margin-top: 5px;"></span>
          <div>
            <div ui:field="titleText" style="font-size: 16px; font-weight: 600; margin-bottom: 6px;"></div>
            <div ui:field="helpText" style="font-size: 13px; opacity: 0.75; line-height: 1.5;"></div>
          </div>
        </div>
        <div class="{style.actions}">
          <a ui:field="refreshBtn" href="#" style="text-decoration: none;"
             class="{style.btn} {style.btnPrimary}">
            <ui:text from="{msg.refreshPage}"/>
          </a>
          <gwt:Anchor href="javascript:;" ui:field="showDetail" visible="false"
                      styleName="{style.btn}">
            <ui:text from="{msg.showErrorDetail}"/>
          </gwt:Anchor>
          <gwt:Anchor href="javascript:;" ui:field="copyBtn" visible="false"
                      styleName="{style.btn}">
            <ui:text from="{msg.copyError}"/>
          </gwt:Anchor>
          <gwt:Anchor href="javascript:;" ui:field="dismissBtn"
                      styleName="{style.btn}">
            <ui:text from="{msg.dismiss}"/>
          </gwt:Anchor>
        </div>
      </div>
      <div ui:field="detail" class="{style.detail}">
        <h3 ui:field="stackHeader" style="margin: 0 0 8px 0; font-size: 12px; font-weight: 500;"></h3>
        <span ui:field="stack" class="{style.stack}"></span>
        <span ui:field="bug"></span>
      </div>
    </div>
  </gwt:HTMLPanel>
</ui:UiBinder>
